# AI LangChain Service Configuration
# Copy to .env and update values

PORT=3002
NODE_ENV=development

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-ada-002

# LangSmith (optional — remove or set LANGCHAIN_TRACING_V2=false to disable)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=expense-tracker-ai-langx
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Agent tuning
MAX_AGENT_ITERATIONS=5
AGENT_TIMEOUT_MS=60000

# Backend connection
BACKEND_BASE_URL=http://localhost:3003

# Auth (must match backend JWT_SECRET)
JWT_SECRET=super_secret_key_change_me_in_production

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:4200
