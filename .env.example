# ─── EXPENSE INSPECTOR — ROOT .env.example ─────────────────────────────────────
# This file documents every environment variable consumed by docker-compose.yaml.
# Copy to .env and fill in real values before running `docker compose up`.
#
# IMPORTANT: Never commit .env to git. It is listed in .gitignore.
#
# cp .env.example .env
# ────────────────────────────────────────────────────────────────────────────────


# ── Shared ──────────────────────────────────────────────────────────────────────

# JWT secret — must be identical for backend and ai-langx.
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret


# ── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call backend/ai-langx directly
# (i.e. without going through nginx).
#
# In production behind nginx, browsers never talk directly to backend or ai-langx
# — all requests are proxied. ALLOWED_ORIGINS guards direct external access only.
#
# Docker local prod (nginx on port 80, browser origin is http://localhost):
ALLOWED_ORIGINS=http://localhost
#
# Real domain example (single domain):
#   ALLOWED_ORIGINS=https://yourdomain.com
#
# Multiple origins (e.g. prod + staging):
#   ALLOWED_ORIGINS=https://yourdomain.com,https://staging.yourdomain.com
#
# Local development (outside Docker):
#   ALLOWED_ORIGINS=http://localhost:4200


# ── OpenAI ──────────────────────────────────────────────────────────────────────

# Required — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional overrides (defaults shown)
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-ada-002


# ── LangSmith (optional) ────────────────────────────────────────────────────────
# Set LANGCHAIN_TRACING_V2=false to disable tracing entirely.
# When enabled, all LangChain runs appear at https://smith.langchain.com
# under the project named LANGCHAIN_PROJECT.
#
# Get your API key from: https://smith.langchain.com → Settings → API Keys

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=expense-tracker-ai-langx
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com


# ── Agent tuning (optional) ──────────────────────────────────────────────────────
# Safe defaults are built into the app. Override here if needed.

MAX_AGENT_ITERATIONS=5
AGENT_TIMEOUT_MS=60000


# ── Debug routes (optional) ──────────────────────────────────────────────────────
# Exposes /ai/debug/* endpoints (stats, chunks, documents, search).
# Disabled by default in production. Enable only for troubleshooting.
# Remember to remove the nginx location block for /ai-langchain/debug/ when disabling.

ENABLE_DEBUG_ROUTES=false
